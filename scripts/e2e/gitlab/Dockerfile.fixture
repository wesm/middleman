ARG GITLAB_BASE_IMAGE=gitlab/gitlab-ce:18.9.5-ce.0
FROM ${GITLAB_BASE_IMAGE}

COPY bootstrap.sh wait.sh /opt/middleman/gitlab-fixture/
COPY fixture-entrypoint.sh /usr/local/bin/middleman-gitlab-fixture-entrypoint

RUN chmod +x \
    /opt/middleman/gitlab-fixture/bootstrap.sh \
    /opt/middleman/gitlab-fixture/wait.sh \
    /usr/local/bin/middleman-gitlab-fixture-entrypoint

CMD ["/usr/local/bin/middleman-gitlab-fixture-entrypoint"]
