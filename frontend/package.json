{
  "name": "middleman-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "vite build --logLevel warn",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run check && bunx tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test --config=playwright-e2e.config.ts",
    "test:e2e:mock": "playwright test --config=playwright.config.ts",
    "demo-workspace": "playwright test --config tests/demo/playwright-demo.config.ts"
  },
  "dependencies": {
    "@lucide/svelte": "1.3.0",
    "@middleman/ui": "workspace:*",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "dompurify": "3.3.3",
    "ghostty-web": "^0.4.0",
    "js-toml": "^1.0.3",
    "marked": "17.0.5",
    "openapi-fetch": "^0.17.0",
    "shiki": "^4.0.2",
    "simple-icons": "^16.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.55.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@testing-library/svelte": "5.2.8",
    "@tsconfig/svelte": "5.0.8",
    "@types/dompurify": "3.2.0",
    "@types/node": "^24.9.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "jsdom": "26.1.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "1.55.1",
    "prettier": "^3.8.1",
    "svelte": "5.55.0",
    "svelte-check": "4.4.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "8.0.3",
    "vitest": "3.2.4"
  }
}
