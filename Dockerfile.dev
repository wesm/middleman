FROM golang:1.26

RUN apt-get update && apt-get install -y --no-install-recommends socat unzip && rm -rf /var/lib/apt/lists/*

# Bun from GitHub release (pinned to match frontend/package.json)
RUN curl -fsSL -o /tmp/bun.zip https://github.com/oven-sh/bun/releases/download/bun-v1.3.11/bun-linux-x64.zip \
    && unzip -q /tmp/bun.zip -d /tmp/bun \
    && mv /tmp/bun/bun-linux-x64/bun /usr/local/bin/bun \
    && chmod +x /usr/local/bin/bun \
    && rm -rf /tmp/bun /tmp/bun.zip

# Air for Go live reload
RUN go install github.com/air-verse/air@v1.65.0

WORKDIR /app
